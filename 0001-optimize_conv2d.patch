+#include "nnacl_c/int8/conv3x3_int8_riscv.h"
+#include <string.h>
+
+// 内联边界检查宏 - 避免函数调用开销
+#define GET_INPUT(input_ptr, iy, ix, ic, H, W, C, zp) \
+  (((iy) >= 0 && (iy) < (H) && (ix) >= 0 && (ix) < (W)) ? (input_ptr[((iy) * (W) + (ix)) * (C) + (ic)] - (zp)) : (-(zp)))
+
+// 滤波器访问宏 - [OC, IC, 3, 3]格式
+#define FILTER_OC_IC(filter, oc, ic, h, w, input_c) (filter[(oc) * (input_c) * 9 + (ic) * 9 + (h) * 3 + (w)])
+
+void Conv3x3Int8Riscv(const int8_t *input, int8_t *output, const int8_t *filter, const int32_t *bias,
+                      int32_t input_zp, const int32_t *quant_scale, int32_t output_zp, uint32_t quant_num,
+                      const int *input_dims, const int *output_dims) {
+  const int batch = input_dims[0];
+  const int input_h = input_dims[1];
+  const int input_w = input_dims[2];
+  const int input_c = input_dims[3];
+
+  const int output_h = output_dims[1];
+  const int output_w = output_dims[2];
+  const int output_c = output_dims[3];
+
+  // 激活函数范围（int8范围）
+  const int32_t output_activation_min = -128;
+  const int32_t output_activation_max = 127;
+
+  // 处理每个batch
+  for (int b = 0; b < batch; b++) {
+    const int8_t *batch_input = input + b * input_h * input_w * input_c;
+    int8_t *batch_output = output + b * output_h * output_w * output_c;
+
+    // 处理每个输出通道
+    for (int oc = 0; oc < output_c; oc++) {
+      // 处理每个输出位置
+      for (int oy = 0; oy < output_h; oy++) {
+        for (int ox = 0; ox < output_w; ox++) {
+          // 初始化累加器
+          int32_t acc = bias[oc];
+
+          // 3x3内核完全展开 - 无嵌套循环
+          // 这是最内层循环，只保留输入通道循环
+          for (int ic = 0; ic < input_c; ic++) {
+            // 加载9个滤波器值
+            int8_t f00 = FILTER_OC_IC(filter, oc, ic, 0, 0, input_c);
+            int8_t f01 = FILTER_OC_IC(filter, oc, ic, 0, 1, input_c);
+            int8_t f02 = FILTER_OC_IC(filter, oc, ic, 0, 2, input_c);
+            int8_t f10 = FILTER_OC_IC(filter, oc, ic, 1, 0, input_c);
+            int8_t f11 = FILTER_OC_IC(filter, oc, ic, 1, 1, input_c);
+            int8_t f12 = FILTER_OC_IC(filter, oc, ic, 1, 2, input_c);
+            int8_t f20 = FILTER_OC_IC(filter, oc, ic, 2, 0, input_c);
+            int8_t f21 = FILTER_OC_IC(filter, oc, ic, 2, 1, input_c);
+            int8_t f22 = FILTER_OC_IC(filter, oc, ic, 2, 2, input_c);
+
+            // 输入原点位置（padding=1）
+            int iy_base = oy - 1;
+            int ix_base = ox - 1;
+
+            // 加载9个输入值（带边界检查）
+            int32_t i00 = GET_INPUT(batch_input, iy_base + 0, ix_base + 0, ic, input_h, input_w, input_c, input_zp);
+            int32_t i01 = GET_INPUT(batch_input, iy_base + 0, ix_base + 1, ic, input_h, input_w, input_c, input_zp);
+            int32_t i02 = GET_INPUT(batch_input, iy_base + 0, ix_base + 2, ic, input_h, input_w, input_c, input_zp);
+            int32_t i10 = GET_INPUT(batch_input, iy_base + 1, ix_base + 0, ic, input_h, input_w, input_c, input_zp);
+            int32_t i11 = GET_INPUT(batch_input, iy_base + 1, ix_base + 1, ic, input_h, input_w, input_c, input_zp);
+            int32_t i12 = GET_INPUT(batch_input, iy_base + 1, ix_base + 2, ic, input_h, input_w, input_c, input_zp);
+            int32_t i20 = GET_INPUT(batch_input, iy_base + 2, ix_base + 0, ic, input_h, input_w, input_c, input_zp);
+            int32_t i21 = GET_INPUT(batch_input, iy_base + 2, ix_base + 1, ic, input_h, input_w, input_c, input_zp);
+            int32_t i22 = GET_INPUT(batch_input, iy_base + 2, ix_base + 2, ic, input_h, input_w, input_c, input_zp);
+
+            // MAC操作 - 完全展开（9次乘法）
+            acc += f00 * i00;
+            acc += f01 * i01;
+            acc += f02 * i02;
+            acc += f10 * i10;
+            acc += f11 * i11;
+            acc += f12 * i12;
+            acc += f20 * i20;
+            acc += f21 * i21;
+            acc += f22 * i22;
+          }
+
+          // Per-channel量化 - 使用简化的缩放
+          // quant_scale[oc] 包含了该通道的量化缩放因子
+          int32_t scaled = (acc * quant_scale[oc] + (1 << 15)) >> 16;  // 简化的requantization
+          scaled += output_zp;
+
+          // 激活函数（clamp）
+          if (scaled < output_activation_min) {
+            scaled = output_activation_min;
+          } else if (scaled > output_activation_max) {
+            scaled = output_activation_max;
+          }
+
+          // 存储输出（NHWC格式）
+          batch_output[(oy * output_w + ox) * output_c + oc] = (int8_t)scaled;
+        }
+      }
+    }
+  }
+}
