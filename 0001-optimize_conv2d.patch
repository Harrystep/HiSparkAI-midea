+#ifndef MINDSPORE_LITE_SRC_LITERT_KERNEL_CPU_NNACL_C_INT8_CONV3X3_INT8_RISCV_H_
+#define MINDSPORE_LITE_SRC_LITERT_KERNEL_CPU_NNACL_C_INT8_CONV3X3_INT8_RISCV_H_
+
+#include <stdint.h>
+#include "nnacl_c/int8/quantize.h"
+#include "nnacl_c/int8/fixed_point.h"
+
+#ifdef __cplusplus
+extern "C" {
+#endif
+
+/**
+ * @brief RISCV优化的3x3卷积算子（无Pack，最少循环）
+ *
+ * 特性：
+ * - 直接在NHWC格式操作，无Pack变换
+ * - 3x3内核完全展开（9次显式MAC）
+ * - 零额外RAM消耗（无临时buffer）
+ * - 最小化FLASH消耗（无Pack代码）
+ * - 仅4层循环嵌套（batch, oc, oy, ox）
+ *
+ * @param input 输入张量，NHWC格式 [N, H, W, IC]
+ * @param output 输出张量，NHWC格式 [N, OH, OW, OC]
+ * @param filter 滤波器 [OC, IC, 3, 3]
+ * @param bias 偏置 [OC]
+ * @param input_zp 输入零点
+ * @param quant_scale 量化scale数组 [output_c]
+ * @param output_zp 输出零点
+ * @param quant_num 量化参数数量（通常为output_channel）
+ * @param input_dims 输入维度 [N, H, W, IC]
+ * @param output_dims 输出维度 [N, OH, OW, OC]
+ */
+void Conv3x3Int8Riscv(const int8_t *input, int8_t *output, const int8_t *filter, const int32_t *bias,
+                      int32_t input_zp, const int32_t *quant_scale, int32_t output_zp, uint32_t quant_num,
+                      const int *input_dims, const int *output_dims);
+
+#ifdef __cplusplus
+}
+#endif
+
+#endif  // MINDSPORE_LITE_SRC_LITERT_KERNEL_CPU_NNACL_C_INT8_CONV3X3_INT8_RISCV_H_
diff --git a/mindspore-lite/tools/converter/micro/coder/opcoders/nnacl/int8/conv2d_3x3_int8_coder.cc b/mindspore-lite/tools/converter/micro/coder/opcoders/nnacl/int8/conv2d_3x3_int8_coder.cc
index 710813e3..2f736798 100644
--- a/mindspore-lite/tools/converter/micro/coder/opcoders/nnacl/int8/conv2d_3x3_int8_coder.cc
+++ b/mindspore-lite/tools/converter/micro/coder/opcoders/nnacl/int8/conv2d_3x3_int8_coder.cc
@@ -248,12 +248,14 @@ int Conv2D3x3Int8Coder::DoCode(CoderContext *const context) {
             {
               "nnacl_c/int8/conv_int8.h",
               "nnacl_c/int8/conv3x3_int8.h",
+              "nnacl_c/int8/conv3x3_int8_riscv.h",
             },
             {
               "pack_int8.c",
               "conv_int8.c",
               "conv3x3_int8.c",
               "conv3x3_int8_low_memory.c",
+              "conv3x3_int8_riscv.c",
               "fixed_point.c",
             });
   }
@@ -297,7 +299,10 @@ int Conv2D3x3Int8Coder::DoCode(CoderContext *const context) {
     code.CodeStruct(scale_ratio_name, conv_quant_args);
     code.CodeArray<int>("input_shape", input_tensor_shape.data(), input_tensor_shape.size(), true);
     code.CodeArray<int>("output_shape", output_tensor_shape.data(), output_tensor_shape.size(), true);
-    code.CodeFunction("Conv3x3Int8OptimzedForOutC", input_tensor_, output_tensor_, filter_addr_, bias_addr_, input_zp,
+
+    // Call new RISCV optimized function (no pack, 3x3 unrolled)
+    // Using same parameter format as old function for compatibility
+    code.CodeFunction("Conv3x3Int8Riscv", input_tensor_, output_tensor_, filter_addr_, bias_addr_, input_zp,
                       scale_ratio_name, output_zp, quant_num, "input_shape", "output_shape");
   }
   context->AppendCode(code.str());
